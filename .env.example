# 超级管理员账号，首次启动会自动创建
ADMIN_USERNAME=admin
ADMIN_PASSWORD=请改成你的管理员密码

# 登录签名密钥，正式部署一定要改成随机长字符串
JWT_SECRET=请改成随机长字符串
JWT_EXPIRE_HOURS=168

# 定时清理僵尸冻结点数记录的密钥（可选）
# 设置后，用外部定时器定期触发清理端点即可，例如每 5 分钟：
#   */5 * * * * curl -s -H "Authorization: Bearer $CRON_SECRET" https://你的域名/api/admin/credits/expire-reservations
# 不设置也能用：仍有 reserve/settle 时的懒触发，且管理员登录后可手动调用该端点。
CRON_SECRET=请改成随机长字符串

# PostgreSQL
# Docker Compose 内默认使用下面这个连接串
DATABASE_URL=postgres://infinite_canvas:infinite_canvas@postgres:5432/infinite_canvas?sslmode=disable

# 如果你是在宿主机本地开发，而不是容器内运行，可改成：
# DATABASE_URL=postgres://infinite_canvas:infinite_canvas@127.0.0.1:5432/infinite_canvas?sslmode=disable

# 前端公开配置
NEXT_PUBLIC_DOC_URL=https://docs.canvas.best
